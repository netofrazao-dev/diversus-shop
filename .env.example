# Supabase — encontre em Project Settings > API no seu projeto Supabase
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_ANON_KEY_AQUI

# WhatsApp da loja — formato internacional, apenas números (código do país + DDD + número)
# Exemplo: Brasil, DDD 91, número 999999999 => 5591999999999
VITE_STORE_WHATSAPP=5500000000000

# Pix da loja (opcional) — se preencher a chave, o checkout mostra QR Code de pagamento.
# Se deixar VITE_STORE_PIX_KEY em branco, essa etapa simplesmente não aparece.
VITE_STORE_PIX_KEY=
VITE_STORE_PIX_NAME=DIVERSUS SHOP
VITE_STORE_PIX_CITY=BRASIL

# Taxa de entrega fixa somada ao total (opcional, padrão R$1,00 se não preencher)
VITE_DELIVERY_FEE=1

# Identificação da empresa (exigido por lei em sites de venda no Brasil)
# Preencha com a razão social (ou seu nome, se for informal/MEI) e o
# CNPJ (ou CPF). Aparece no rodapé e na Política de Privacidade.
VITE_STORE_LEGAL_NAME=
VITE_STORE_DOCUMENT=
